{
  "manifest_version": 3,
  "name": "One Cart",
  "version": "1.0.0",
  "description": "Save products from any website into one cart.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:5000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to One Cart"
  }
}